// UTILITY FUNCTIONS

// Zero-safe function to prevent division by zero
fz(_val) => _val == 0 ? 1 : _val

// Session-based moving average calculation
day_ma(_start, _type, source, length) =>
    bars_since_start = fz(ta.barssince(_start))
    valid_length = bars_since_start < length ? bars_since_start : length
    var float ma = na
    
    if _type == "EMA"
        k = 2 / (valid_length + 1)
        ma := (source * k) + (nz(ma[1]) * (1 - k))
    else if _type == "RMA"
        alpha = 1 / valid_length
        ma := alpha * source + (1 - alpha) * nz(ma[1])
    else if _type == "SMA"
        ma := ta.sma(source, valid_length)
    else if _type == "WMA"
        ma := ta.wma(source, valid_length)
    ma



// Session-based Anchor VWAP calculation anchored to daily open
session_anchor_vwap(_start) =>
    var float anchor_price = na
    var float sum_pv = 0.0
    var float sum_v = 0.0
    
    if _start
        anchor_price := open  // Anchor to session opening price
        sum_pv := 0.0
        sum_v := 0.0
    
    float vwap_val = na
    if not na(anchor_price)
        float current_pv = close * volume
        sum_pv += current_pv
        sum_v += volume
        vwap_val := sum_v > 0 ? sum_pv / sum_v : anchor_price
    else
        vwap_val := close
    vwap_val

// Line style converter
linestyle(_input) =>
    _input == "___" ? line.style_solid :
     _input == "- - -" ? line.style_dashed :
     _input == ". . ." ? line.style_dotted : line.style_solid

// Get next integer value
get_1up(_val) => (_val - math.floor(_val)) > 0 ? int(math.floor(_val) + 1) : int(_val)

// Parse session end (HHMM-HHMM) into total minutes from midnight
session_end_minutes(_session) =>
    int slen = str.length(_session)
    slen >= 9 ?
      int(str.tonumber(str.substring(_session, 5, 7))) * 60 +
      int(str.tonumber(str.substring(_session, 7, 9))) : na

// Format countdown as HH:MM
fmt_hhmm(_minutes) =>
    int hrs = _minutes / 60
    int mins = math.abs(_minutes % 60)
    str.tostring(hrs, "00") + ":" + str.tostring(mins, "00")

// DATA TYPES

type target
    line ln
    label lab

// Determine whether a breakout day is profitable using the script's existing rules.
breakout_is_profit(bool _broke_high, bool _broke_low, bool _first_high, bool _first_low, float _close, float _orh, float _orl) =>
    bool result = false
    if _broke_high and _broke_low
        result := _first_low ? _close <= _orh : _close >= _orl
    else if _broke_high
        result := _close >= _orl
    else if _broke_low
        result := _close <= _orh
    result

loss_adverse_distance(bool _broke_high, bool _broke_low, bool _first_high, bool _first_low, float _close, float _orh, float _orl) =>
    float distance = 0.0
    if _broke_high and _broke_low
        distance := _first_low ? _close - _orh : _orl - _close
    else if _broke_high
        distance := _orl - _close
    else if _broke_low
        distance := _close - _orh
    math.max(0.0, distance)

loss_points_from_distance(float _distance) =>
    int units = int(math.round(_distance))
    -math.min(1500, units * 100)

session_shade_color(float _close, float _open, float _orh, float _orl, bool _broke_high, bool _broke_low, bool _first_high, bool _first_low, bool _cutoff_locked, float _vix_open) =>
    color result = color(na)
    if not na(_open) and not na(_orh) and not na(_orl)
        float width_threshold = _open * orWidthThresholdPct
        float or_range = _orh - _orl
        bool session_vix_untradable = not na(_vix_open) and _vix_open > vixUntradableThreshold
        if or_range < width_threshold or session_vix_untradable
            result := color.new(widthErrorColor, 85)
        else
            if _broke_high or _broke_low
                bool is_profit = breakout_is_profit(_broke_high, _broke_low, _first_high, _first_low, _close, _orh, _orl)
                result := color.new(is_profit ? profitColor : lossColor, 85)
            else if _cutoff_locked
                result := color.new(widthErrorColor, 85)
            else
                result := color.new(errorColor, 85)
    result

has_valid_or(float _orh, float _orl) =>
    not na(_orh) and not na(_orl) and _orh != _orl

prune_hist_boxes(array<box> _boxes) =>
    while array.size(_boxes) > maxHistSessions
        box old_bx = array.shift(_boxes)
        if not na(old_bx)
            old_bx.delete()

prune_hist_labels(array<label> _labels) =>
    while array.size(_labels) > maxHistSessions
        label old_lab = array.shift(_labels)
        if not na(old_lab)
            old_lab.delete()

process_session_stats(float _close, float _orh, float _orl, float _open, bool _broke_high, bool _broke_low, bool _first_high, bool _first_low, bool _cutoff_locked, float _vix_open) =>
    int session_points = 0
    string status = "Pending"
    int width_error_inc = 0
    int profit_inc = 0
    int loss_inc = 0
    int error_inc = 0
    if not na(_open) and not na(_orh) and not na(_orl)
        float width_threshold = _open * orWidthThresholdPct
        float or_range = _orh - _orl
        bool vix_untradable = not na(_vix_open) and _vix_open > vixUntradableThreshold
        if or_range < width_threshold or vix_untradable
            width_error_inc := 1
            status := or_range < width_threshold ? "Width Error" : "VIX Untradable"
        else
            if _broke_high or _broke_low
                bool is_profit = breakout_is_profit(_broke_high, _broke_low, _first_high, _first_low, _close, _orh, _orl)
                if is_profit
                    profit_inc := 1
                    session_points := 100
                    status := "Profit Day"
                else
                    loss_inc := 1
                    float loss_distance = loss_adverse_distance(_broke_high, _broke_low, _first_high, _first_low, _close, _orh, _orl)
                    session_points := loss_points_from_distance(loss_distance)
                    status := "Loss Day"
            else
                error_inc := 1
                status := _cutoff_locked ? "Cutoff Day (No Breakout)" : "Error Day"
    [session_points, status, width_error_inc, profit_inc, loss_inc, error_inc]

points_label_text(int _points) =>
    (_points > 0 ? "+" : "") + str.tostring(_points) + " pts"

create_points_label(int _bar_idx, float _price, int _points) =>
    color label_color = _points > 0 ? profitColor : _points < 0 ? lossColor : errorColor
    label.new(_bar_idx, _price, text = points_label_text(_points), tooltip = "Points added/subtracted: " + points_label_text(_points), style = _points >= 0 ? label.style_label_up : label.style_label_down, color = label_color, textcolor = color.white, size = size.small)

delete_target(target _target, bool _delete_line) =>
    if _delete_line and not na(_target.ln)
        _target.ln.delete()
    if not na(_target.lab)
        _target.lab.delete()

// STATE VARIABLES

// Arrays for targets and signals
var up_targs = array.new<target>()
var down_targs = array.new<target>()
var signals = array.new<label>()

// Session state tracking
var bool or_sesh = false
var bool or_token = false

// Opening Range values
var float orh = na  // Opening Range High
var float orl = na  // Opening Range Low
var float hst = na  // Highest since target
var float lst = na  // Lowest since target
var float prev_orm = na  // Previous Opening Range Middle
var int or_start_idx = na

// Target counters
var int up_count = na
var int down_count = na

// Visual elements
var box or_bx = na
var array<box> hist_shade_boxes = array.new<box>()
var array<label> hist_outcome_labels = array.new<label>()
var target h_ln = target.new(na, na)
var target l_ln = target.new(na, na)



// Bias and signal tracking
var int day_dir = 0
var bool down_check = false
var bool up_check = false
bool down_signal = false
bool up_signal = false

// Enhanced statistics tracking
var int days_counted = 0
var int width_error_days = 0
var int profit_days = 0
var int loss_days = 0
var int error_days = 0
var int total_points = 0
var bool daily_broke_high = false
var bool daily_broke_low = false
var bool first_breakout_high = false  // Tracks if first breakout was high
var bool first_breakout_low = false   // Tracks if first breakout was low
var bool breakout_cutoff_locked = false  // Prevents late breakouts after cutoff
var float session_open_price = na
var table stats_table = na
var bool session_processed = false
var bool is_tradable_day = false
var bool is_vix_untradable_day = false
var label day_outcome_label = na
var bool width_error_shown = false
var string current_session_status = "Pending"

// CORE CALCULATIONS

// Opening Range metrics
float orm = math.avg(orh, orl)  // Opening Range Middle
float orw = math.abs(orh - orl)  // Opening Range Width

// Target source selection
float h_src = tSrc == "Close" ? close : high
float l_src = tSrc == "Close" ? close : low
float vix_close = request.security("CBOE:VIX", timeframe.period, close, lookahead = barmerge.lookahead_off)
float vix_open_daily = request.security("CBOE:VIX", "D", open, lookahead = barmerge.lookahead_off)

// Performance optimization
max_bars_back(close, 500)
max_bars_back(daily_broke_high, 100)
max_bars_back(daily_broke_low, 100)

// SESSION DETECTION

bool new_tf = timeframe.change(orTF)

if crTog
    or_sesh := not na(time(timeframe.period, crSesh, tz))
else 
    if session.isfirstbar
        or_sesh := true
    else if not session.isfirstbar and new_tf
        or_sesh := false

bool or_start = or_sesh and not or_sesh[1]
bool or_end = or_sesh[1] and not or_sesh

// Are we currently inside regular market hours?
bool in_market_hours = not na(time(timeframe.period, mktSesh, tz))

// Daily cutoff at 12:00 (uses selected timezone)
int cutoff_ts = timestamp(tz, year, month, dayofmonth, 12, 0)
bool past_cutoff_time = time >= cutoff_ts
bool valid_or = has_valid_or(orh, orl)

// SESSION START PROCESSING

if or_start
    // Finalize and archive previous session shade before starting a new day
    if showHist and not na(or_bx) and has_valid_or(orh, orl)
        or_bx.set_right(bar_index - 1)
        color archived_shade = session_shade_color(close[1], session_open_price, orh, orl, daily_broke_high, daily_broke_low, first_breakout_high, first_breakout_low, breakout_cutoff_locked, vix_open_daily[1])
        if not na(archived_shade)
            or_bx.set_bgcolor(archived_shade)
        array.push(hist_shade_boxes, or_bx)
        prune_hist_boxes(hist_shade_boxes)
        or_bx := na

    // Process previous session statistics (orh/orl still hold prior session until reset below)
    if not session_processed and has_valid_or(orh, orl) and days_counted >= 0
        days_counted += 1
        
        float prev_close = close[1]
        float prev_orh = orh
        float prev_orl = orl
        bool prev_broke_high = daily_broke_high
        bool prev_broke_low = daily_broke_low
        bool prev_first_high = first_breakout_high
        bool prev_first_low = first_breakout_low
        bool prev_cutoff_locked = breakout_cutoff_locked
        float prev_session_open = session_open_price
        
        [prev_session_points, prev_status, w_inc, p_inc, l_inc, e_inc] = process_session_stats(prev_close, prev_orh, prev_orl, prev_session_open, prev_broke_high, prev_broke_low, prev_first_high, prev_first_low, prev_cutoff_locked, vix_open_daily[1])
        width_error_days += w_inc
        profit_days += p_inc
        loss_days += l_inc
        error_days += e_inc
        total_points += prev_session_points
        if showHist
            label prev_lab = create_points_label(bar_index - 1, prev_close, prev_session_points)
            array.push(hist_outcome_labels, prev_lab)
            prune_hist_labels(hist_outcome_labels)
        session_processed := true
    
    // Clean up previous session visuals
    for targ in up_targs
        delete_target(targ, not showHist)

    for targ in down_targs
        delete_target(targ, not showHist)

    for lab in signals
        if not showHist and not na(lab)
            lab.delete()

    if not showHist
        if not na(or_bx)
            or_bx.delete()
        delete_target(h_ln, true)
        delete_target(l_ln, true)

    if showHist
        delete_target(h_ln, false)
        delete_target(l_ln, false)
    up_targs.clear()
    down_targs.clear()
    
    if not na(day_outcome_label) and not showHist
        day_outcome_label.delete()
    day_outcome_label := na

    or_start_idx := bar_index

    // Initialize new session
    orh := high
    orl := low
    prev_orm := orm[1]
    up_count := 0
    down_count := 0
    up_check := true
    down_check := true
    
    // Reset tracking variables
    daily_broke_high := false
    daily_broke_low := false
    first_breakout_high := false
    first_breakout_low := false
    breakout_cutoff_locked := false
    session_open_price := open
    session_processed := false
    is_tradable_day := false
    is_vix_untradable_day := false
    width_error_shown := false
    current_session_status := "Pending"

    or_bx := box.new(bar_index, high, bar_index, low, bgcolor = orFillColor, border_width = 0)
    or_token := false

// DURING SESSION PROCESSING

if or_sesh
    if high > orh
        orh := high
    if low < orl
        orl := low
    if orh != orl
        or_token := true
        
// SESSION END PROCESSING

if or_end and or_token
    h_ln := target.new(line.new(or_start_idx, orh, bar_index, orh, color = orColor), label.new(bar_index, orh, text = "ORH", tooltip = str.tostring(orh, format.mintick), style = label.style_label_left, color = invis, textcolor = color.new(orColor, 0), size = txtSize))
    
    l_ln := target.new(line.new(or_start_idx, orl, bar_index, orl, color = orColor), label.new(bar_index, orl, text = "ORL", tooltip = str.tostring(orl, format.mintick), style = label.style_label_left, color = invis, textcolor = color.new(orColor, 0), size = txtSize))
    
    hst := orh + (orw * tPer)
    lst := orl - (orw * tPer)

    day_dir := orm > prev_orm ? 1 : orm < prev_orm ? -1 : 0
    
    // Check tradability immediately after session
    if not na(session_open_price) and not na(orh) and not na(orl)
        float width_threshold = session_open_price * orWidthThresholdPct
        float or_range = orh - orl
        is_vix_untradable_day := not na(vix_open_daily) and vix_open_daily > vixUntradableThreshold
        is_tradable_day := or_range >= width_threshold and not is_vix_untradable_day
        
        if not is_tradable_day and not width_error_shown
            width_error_shown := true
            current_session_status := or_range < width_threshold ? "Width Error" : "VIX Untradable"

// BREAKOUT TRACKING

if not or_sesh and or_token and not na(orh) and not na(orl) and is_tradable_day
    // Lock the session once cutoff passes without a breakout
    if not breakout_cutoff_locked and not daily_broke_high and not daily_broke_low and past_cutoff_time
        breakout_cutoff_locked := true
        current_session_status := "Cutoff (No Breakout)"

    if not breakout_cutoff_locked
        if close > orh and not daily_broke_high
            daily_broke_high := true
            if not first_breakout_high and not first_breakout_low
                first_breakout_high := true
            current_session_status := "Broke High"
        if close < orl and not daily_broke_low
            daily_broke_low := true
            if not first_breakout_high and not first_breakout_low
                first_breakout_low := true
            current_session_status := "Broke Low"
    
    // Update status based on current situation
    if breakout_cutoff_locked and not daily_broke_high and not daily_broke_low
        current_session_status := "Cutoff (No Breakout)"
    else if daily_broke_high and daily_broke_low
        current_session_status := "Both Breakouts"
    else if daily_broke_high
        current_session_status := close >= orl ? "Potential Profit (High)" : "Potential Loss (High)"
    else if daily_broke_low
        current_session_status := close <= orh ? "Potential Profit (Low)" : "Potential Loss (Low)"
    else if not daily_broke_high and not daily_broke_low
        current_session_status := "No Breakout Yet"

// Final session processing — score at confirmed session close
if session.islastbar and barstate.isconfirmed and not session_processed and valid_or
    days_counted += 1
    session_processed := true
    [session_points, sess_status, w_inc, p_inc, l_inc, e_inc] = process_session_stats(close, orh, orl, session_open_price, daily_broke_high, daily_broke_low, first_breakout_high, first_breakout_low, breakout_cutoff_locked, vix_open_daily)
    width_error_days += w_inc
    profit_days += p_inc
    loss_days += l_inc
    error_days += e_inc
    total_points += session_points
    is_vix_untradable_day := not na(vix_open_daily) and vix_open_daily > vixUntradableThreshold
    current_session_status := sess_status
    label outcome_lab = create_points_label(bar_index, close, session_points)
    if showHist
        array.push(hist_outcome_labels, outcome_lab)
        prune_hist_labels(hist_outcome_labels)
    else
        if not na(day_outcome_label)
            day_outcome_label.delete()
        day_outcome_label := outcome_lab
    if not na(or_bx)
        color final_shade = session_shade_color(close, session_open_price, orh, orl, daily_broke_high, daily_broke_low, first_breakout_high, first_breakout_low, breakout_cutoff_locked, vix_open_daily)
        if not na(final_shade)
            or_bx.set_bgcolor(final_shade)
        or_bx.set_right(bar_index)
    else if showHist
        // Chart ended without a live box reference — recreate archived shade for last session
        color final_shade = session_shade_color(close, session_open_price, orh, orl, daily_broke_high, daily_broke_low, first_breakout_high, first_breakout_low, breakout_cutoff_locked, vix_open_daily)
        if not na(final_shade) and not na(or_start_idx)
            box last_bx = box.new(or_start_idx, orh, bar_index, orl, bgcolor = final_shade, border_width = 0)
            array.push(hist_shade_boxes, last_bx)
            prune_hist_boxes(hist_shade_boxes)

// LEVEL EXTENSIONS

if not or_sesh and or_token
    if not na(h_ln.ln)
        h_ln.ln.set_x2(bar_index)
    if not na(l_ln.ln)
        l_ln.ln.set_x2(bar_index)
    if not na(h_ln.lab)
        h_ln.lab.set_x(bar_index)
    if not na(l_ln.lab)
        l_ln.lab.set_x(bar_index)

// SESSION STATUS SHADE — single box from OR start through session close
if (or_sesh or valid_or) and not na(or_bx)
    or_bx.set_top(orh)
    or_bx.set_bottom(orl)
    or_bx.set_right(bar_index)
    color shade_color = or_sesh ? orFillColor : session_shade_color(close, session_open_price, orh, orl, daily_broke_high, daily_broke_low, first_breakout_high, first_breakout_low, breakout_cutoff_locked, vix_open_daily)
    if not na(shade_color)
        or_bx.set_bgcolor(shade_color)

// TARGET CALCULATIONS

if h_src > hst
    hst := h_src
if l_src < lst
    lst := l_src

int up_max = get_1up((hst - orh) / (orw * tPer))
int down_max = get_1up((orl - lst) / (orw * tPer))

int up_cur = math.max(0, get_1up((h_src - orh) / (orw * tPer)))
int down_cur = math.max(0, get_1up((orl - l_src) / (orw * tPer)))

// SIGNAL DETECTION

// Signal logic for tradable days only
if not breakout_cutoff_locked and is_tradable_day and (close > orm and down_check == false)
    down_check := true

bool xdown = ta.crossunder(close, orl)
bool xdown2 = ta.crossunder(close, orl - orw * tPer)
if not breakout_cutoff_locked and is_tradable_day and (useBias ? ((day_dir != 1 and xdown) or (day_dir == 1 and xdown2)) : xdown) and down_check
    down_signal := true
    down_check := false

if not breakout_cutoff_locked and is_tradable_day and (close < orm and up_check == false)
    up_check := true

bool xup = ta.crossover(close, orh)
bool xup2 = ta.crossover(close, orh + orw * tPer)
if not breakout_cutoff_locked and is_tradable_day and (useBias ? ((day_dir != -1 and xup) or (day_dir == -1 and xup2)) : xup) and up_check
    up_signal := true
    up_check := false

// Alertable opening range levels. These are series plots/conditions so TradingView
// can reference ORH/ORL in the alert dialog, unlike the visual line objects above.
float alertable_orh = not or_sesh and or_token and not na(orh) ? orh : na
float alertable_orl = not or_sesh and or_token and not na(orl) ? orl : na
bool confirmed_alert_bar = barstate.isconfirmed
bool price_cross_above_orh = confirmed_alert_bar and ta.crossover(close, alertable_orh)
bool price_cross_above_orl = confirmed_alert_bar and ta.crossover(close, alertable_orl)
bool price_cross_below_orl = confirmed_alert_bar and ta.crossunder(close, alertable_orl)

alertcondition(price_cross_above_orh, title = "Price Cross Above ORH", message = "Price crossed above the Opening Range High (ORH) after bar close.")
alertcondition(price_cross_above_orl, title = "Price Cross Above ORL", message = "Price crossed above the Opening Range Low (ORL) after bar close.")
alertcondition(price_cross_below_orl, title = "Price Cross Below ORL", message = "Price crossed below the Opening Range Low (ORL) after bar close.")
alertcondition(price_cross_above_orh or price_cross_below_orl, title = "Price Breakout ORH/ORL", message = "Price broke out of the Opening Range after bar close.")

// SESSION TREND INDICATORS

float session_sma = showSMA ? day_ma(or_start, "SMA", close, smaLen) : na
float session_ema = showEMA ? day_ma(or_start, "EMA", close, emaLen) : na
float session_rma = showRMA ? day_ma(or_start, "RMA", close, rmaLen) : na
float session_wma = showWMA ? day_ma(or_start, "WMA", close, wmaLen) : na

// Session Anchor VWAP calculation
float session_anchor_vwap_val = showVWAP ? session_anchor_vwap(or_start) : na

// DISPLAY & VISUALIZATION

// Market close countdown and VIX snapshot
int mc_minutes_total = session_end_minutes(mktSesh)
int mc_hour = na(mc_minutes_total) ? na : mc_minutes_total / 60
int mc_minute = na(mc_minutes_total) ? na : mc_minutes_total % 60
int market_close_ts = not na(mc_hour) and not na(mc_minute) ? timestamp(tz, year, month, dayofmonth, mc_hour, mc_minute) : na
float ms_to_close = not na(market_close_ts) ? (market_close_ts - timenow) : na
int mins_to_close = not na(ms_to_close) ? int(math.max(0, math.floor(ms_to_close / 60000))) : na
string market_close_countdown = not na(mins_to_close) and mins_to_close > 0 ? fmt_hhmm(mins_to_close) : "Closed"

string vix_display = na(vix_close) ? "N/A" : str.tostring(vix_close, "#.##")
color vix_bg = na(vix_close) ? color.rgb(30,34,45) : ((not na(vix_open_daily) and vix_open_daily > vixUntradableThreshold) ? color.new(widthErrorColor, 70) : color.new(color.green, 70))

float or_width_pct = not na(session_open_price) and not na(orh) and not na(orl) ? math.abs(orh - orl) / session_open_price * 100 : na
color width_bg = na(or_width_pct) ? color.rgb(30,34,45) : (or_width_pct >= (orWidthThresholdPct * 100) ? color.new(color.green, 70) : color.new(widthErrorColor, 70))

// Statistics Table (configurable location/size, horizontal layout)
if barstate.islast and showTable
    if not na(stats_table)
        table.delete(stats_table)

    float profit_rate = days_counted > 0 ? math.round((profit_days / days_counted) * 100, 2) : 0.0
    float loss_rate = days_counted > 0 ? math.round((loss_days / days_counted) * 100, 2) : 0.0
    float error_rate = days_counted > 0 ? math.round((error_days / days_counted) * 100, 2) : 0.0
    bool is_current_session = valid_or and not session_processed

    var table_pos = position.top_right
    if tableLocation == "Bottom Right"
        table_pos := position.bottom_right
    else if tableLocation == "Bottom Left"
        table_pos := position.bottom_left

    string tSize = tableTextSize
    var string mappedSize = size.small
    mappedSize := tSize == "Auto" ? size.auto : mappedSize
    mappedSize := tSize == "Huge" ? size.huge : mappedSize
    mappedSize := tSize == "Large" ? size.large : mappedSize
    mappedSize := tSize == "Normal" ? size.normal : mappedSize
    mappedSize := tSize == "Small" ? size.small : mappedSize
    mappedSize := tSize == "Tiny" ? size.tiny : mappedSize

    int num_cols = 0
    if showBacktestColumns
        num_cols += 5
    if showWidthPctColumn
        num_cols += 1
    if showMarketCloseColumn
        num_cols += 1
    if showVIXColumn
        num_cols += 1
    if showORHORL and in_market_hours and not na(orh) and not na(orl)
        num_cols += 2

    if num_cols > 0
        stats_table := table.new(table_pos, num_cols, 2, bgcolor = color.rgb(30,34,45), border_width = 1, frame_width = 1, frame_color = color.rgb(55,58,70), border_color = color.rgb(55,58,70))

        int col_idx = 0

        if showBacktestColumns
            table.cell(stats_table, col_idx, 0, "Days", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            table.cell(stats_table, col_idx, 1, str.tostring(days_counted + (is_current_session ? 1 : 0)), text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            col_idx += 1

            table.cell(stats_table, col_idx, 0, "Profit", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            table.cell(stats_table, col_idx, 1, str.tostring(profit_days) + " (" + str.tostring(profit_rate, "#.##") + "%)", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            col_idx += 1

            table.cell(stats_table, col_idx, 0, "Loss", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            table.cell(stats_table, col_idx, 1, str.tostring(loss_days) + " (" + str.tostring(loss_rate, "#.##") + "%)", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            col_idx += 1

            table.cell(stats_table, col_idx, 0, "Error", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            table.cell(stats_table, col_idx, 1, str.tostring(error_days) + " (" + str.tostring(error_rate, "#.##") + "%)", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            col_idx += 1

            color points_bg = total_points > 0 ? color.new(color.green, 70) : total_points < 0 ? color.new(color.red, 70) : color.rgb(30,34,45)
            table.cell(stats_table, col_idx, 0, "Points", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            table.cell(stats_table, col_idx, 1, str.tostring(total_points), text_color = color.white, text_size = mappedSize, bgcolor = points_bg)
            col_idx += 1

        if showWidthPctColumn
            string width_text = na(or_width_pct) ? "N/A" : str.tostring(or_width_pct, "#.###") + "%"
            table.cell(stats_table, col_idx, 0, "Width %", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            table.cell(stats_table, col_idx, 1, width_text, text_color = color.white, text_size = mappedSize, bgcolor = width_bg)
            col_idx += 1

        if showMarketCloseColumn
            table.cell(stats_table, col_idx, 0, "Mkt Close", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            table.cell(stats_table, col_idx, 1, market_close_countdown, text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            col_idx += 1

        if showVIXColumn
            table.cell(stats_table, col_idx, 0, "VIX", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            table.cell(stats_table, col_idx, 1, vix_display, text_color = color.white, text_size = mappedSize, bgcolor = vix_bg)
            col_idx += 1

        if showORHORL and in_market_hours and not na(orh) and not na(orl)
            table.cell(stats_table, col_idx, 0, "ORH", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            table.cell(stats_table, col_idx, 1, str.tostring(orh, format.mintick), text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            col_idx += 1

            table.cell(stats_table, col_idx, 0, "ORL", text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))
            table.cell(stats_table, col_idx, 1, str.tostring(orl, format.mintick), text_color = color.white, text_size = mappedSize, bgcolor = color.rgb(30,34,45))


// Trend Indicator Plots
plot(alertable_orh, "Opening Range High (ORH)", color=orColor, linewidth=1, display=display.none)
plot(alertable_orl, "Opening Range Low (ORL)", color=orColor, linewidth=1, display=display.none)
plot(or_start ? na : session_sma, "Session SMA", color=showSMA ? smaColor : na, linewidth=2)
plot(or_start ? na : session_ema, "Session EMA", color=showEMA ? emaColor : na, linewidth=2)
plot(or_start ? na : session_rma, "Session RMA", color=showRMA ? rmaColor : na, linewidth=2)
plot(or_start ? na : session_wma, "Session WMA", color=showWMA ? wmaColor : na, linewidth=2)

// Session Anchor VWAP plot
plot(or_start ? na : session_anchor_vwap_val, "Session Anchor VWAP", color=showVWAP ? vwapColor : na, linewidth=2)

// Target Generation - only show targets when price closes outside opening range
if not or_sesh and or_token
    // Check if price has closed above OR high (show upward targets)
    bool show_up_targets = close > orh
    // Check if price has closed below OR low (show downward targets)  
    bool show_down_targets = close < orl
    
    if up_count < up_max and tTog and show_up_targets
        for i = (up_count + 1) to up_max 
            up_targs.push(target.new(
              line.new(bar_index - 1, (orh + orw * tPer * i), bar_index, (orh + (orw * tPer * i)), 
                      color = green, style = linestyle(tStyle)),
              label.new(bar_index, (orh + orw * tPer * i), text = str.tostring(i), 
                       tooltip = str.tostring(orh + orw * tPer * i, format.mintick), 
                       style = label.style_label_left, color = invis, 
                       textcolor = color.new(green, 0), size = txtSize)))
            if i == up_max
                up_count := up_max
                
    if down_count < down_max and tTog and show_down_targets
        for i = (down_count + 1) to down_max
            down_targs.push(target.new(
              line.new(bar_index - 1, (orl - orw * tPer * i), bar_index, (orl - (orw * tPer * i)), 
                      color = red, style = linestyle(tStyle)),
              label.new(bar_index, (orl - orw * tPer * i), text = str.tostring(i), 
                       tooltip = str.tostring(orl - orw * tPer * i, format.mintick), 
                       style = label.style_label_left, color = invis, 
                       textcolor = color.new(red, 0), size = txtSize)))
            if i == down_max
                down_count := down_max

// Target Display Logic
if tDispType == "Extended" and tTog
    for targ in up_targs
        if not na(targ.ln)
            targ.ln.set_x2(bar_index)
        if not na(targ.lab)
            targ.lab.set_x(bar_index)
    for targ in down_targs
        if not na(targ.ln)
            targ.ln.set_x2(bar_index)
        if not na(targ.lab)
            targ.lab.set_x(bar_index)

if tDispType == "Adaptive" and tTog
    for targ in up_targs
        if not na(targ.ln) and targ.ln.get_y1() <= (orh + (orw * tPer * (up_cur))) and targ.ln.get_y1() >= (orh + (orw * tPer * (up_cur - 2)))
            targ.ln.set_x2(bar_index + 1)
            if not na(targ.lab)
                targ.lab.set_x(bar_index + 1)
    for targ in down_targs
        if not na(targ.ln) and targ.ln.get_y1() <= (orl - (orw * tPer * (down_cur - 2))) and targ.ln.get_y1() >= (orl - (orw * tPer * (down_cur)))
            targ.ln.set_x2(bar_index + 1)
            if not na(targ.lab)
                targ.lab.set_x(bar_index + 1)

// Breakout Signals Display
if up_signal and sigTog and is_tradable_day
    signals.push(label.new(bar_index, orl,
      style = label.style_label_center, 
      text = "\n▲", 
      color = invis, 
      textcolor = upSigColor, 
      size = sigSize))

if down_signal and sigTog and is_tradable_day
    signals.push(label.new(bar_index, orh,
      style = label.style_label_center, 
      text = "▼\n",
      color = invis, 
      textcolor = downSigColor, 
      size = sigSize))
